{
  "expo": {
    "name": "Rizz AI",
    "slug": "rizz-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rizzai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rizzai.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Rizz AI needs access to your photo library to upload conversation screenshots."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C5D8F0",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.rizzai.app",
      "permissions": ["android.permission.READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#C5D8F0",
          "dark": {
            "backgroundColor": "#1F2123"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rizz AI needs access to your photos to analyze conversation screenshots."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
