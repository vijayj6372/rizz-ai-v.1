{
  "expo": {
    "name": "Rizz AI",
    "slug": "rizz-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rizz ai - logo.png",
    "scheme": "rizzai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rizzai.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Rizz AI needs access to your photo library to upload conversation screenshots."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A0A2E",
        "foregroundImage": "./assets/images/rizz ai - logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.rizzai.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/rizz ai - logo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/rizz ai - logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#1A0A2E",
          "dark": {
            "backgroundColor": "#1A0A2E"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rizz AI needs access to your photos to analyze conversation screenshots."
        }
      ],
      "expo-audio",
      "react-native-google-mobile-ads"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "5e8522e2-3aa5-4b26-82ab-359add348ffb"
      }
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-9793356380101545~6278569788",
    "ios_app_id": "ca-app-pub-9793356380101545~6278569788"
  }
}
